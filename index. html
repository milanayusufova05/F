 <!DOCTYPE html>

<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Эдильбаева Регина Ренатовна — Косметолог · Новый Уренгой</title>
<link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════
   PALETTE  — shell / stone / sand / coffee
═══════════════════════════════════════ */
:root{
  --bg:      #FFFFFF;   /* pure white             */
  --bg2:     #FAF8F5;   /* milky moments          */
  --shell:   #F5F2EE;   /* card / section surface */
  --stone:   #E0D4C8;   /* subtle divider         */
  --coffee:  #7A5C3A;   /* кофейный акцент */
  --coffee2: #5A4228;   /* тёмный кофе     */
  --sage:    #7A5C3A;   /* кнопки кофе     */
  --sage2:   #5A4228;   /* hover кофе      */
  --text:    #2E2010;   /* тёмный кофе     */
  --text2:   #5A4030;   /* тело кофе       */
  --muted:   #9A8060;   /* приглушённый бордо     */
  --line:    rgba(90,65,40,.07);
  --linesm:  rgba(90,65,40,.04);
  --glass:   rgba(255,255,255,.65);
  --glass2:  rgba(255,255,255,.45);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;}

/* ── AMBIENT BLOBS (always behind content) ── */
.blobs{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;}
.blob{position:absolute;border-radius:50%;filter:blur(64px);}
.b1{width:480px;height:480px;top:-10%;right:-8%;background:radial-gradient(circle,rgba(220,210,200,.12) 0%,transparent 68%);animation:bf 10s ease-in-out infinite;}
.b2{width:380px;height:380px;bottom:-8%;left:-6%;background:radial-gradient(circle,rgba(220,210,200,.1) 0%,transparent 68%);animation:bf 13s ease-in-out infinite reverse;}
.b3{width:260px;height:260px;top:40%;left:28%;background:radial-gradient(circle,rgba(220,210,200,.09) 0%,transparent 68%);animation:bf 17s ease-in-out infinite 4s;}
.b4{width:200px;height:200px;top:15%;right:22%;background:radial-gradient(circle,rgba(210,195,178,.16) 0%,transparent 68%);animation:bf 22s ease-in-out infinite 2s;}
@keyframes bf{0%,100%{transform:scale(1)translateY(0);}50%{transform:scale(1.08)translateY(-18px);}}

/* ── NAV ── */
nav{
position:fixed;top:0;left:0;right:0;z-index:300;
height:64px;padding:0 28px;
display:flex;justify-content:space-between;align-items:center;
background:rgba(255,255,255,.92);
backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
border-bottom:1px solid var(–linesm);
}
.nav-logo-wrap{display:flex;flex-direction:column;gap:0px;line-height:1;}
.nav-script{font-family:‘Alex Brush’,cursive;font-size:1.9rem;color:var(–coffee);line-height:1;}
.nav-sub{font-size:.55rem;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(–muted);}
.nav-menu{display:none;gap:32px;list-style:none;}
.nav-menu a{text-decoration:none;font-size:.7rem;font-weight:400;letter-spacing:2px;text-transform:uppercase;color:var(–muted);transition:color .25s;}
.nav-menu a:hover{color:var(–text);}
.nav-cta{
background:var(–sage);color:#fff;border:none;
padding:10px 22px;border-radius:50px;
font-family:‘DM Sans’,sans-serif;font-size:.68rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;
cursor:pointer;transition:all .3s;-webkit-appearance:none;
}
.nav-cta:hover{background:var(–sage2);transform:translateY(-1px);}

/* ── HERO ── */
.hero{
min-height:100svh;
display:flex;flex-direction:column;justify-content:center;
padding:90px 28px 72px;
position:relative;z-index:1;overflow:hidden;
}
/* big decorative circle */
.hero-circle-deco{
position:absolute;width:min(88vw,500px);height:min(88vw,500px);
border-radius:50%;border:1px solid rgba(216,200,180,.35);
right:-15%;top:50%;transform:translateY(-50%);pointer-events:none;
}
.hero-circle-deco2{
position:absolute;width:min(68vw,380px);height:min(68vw,380px);
border-radius:50%;border:1px solid rgba(120,92,58,.08);
right:-8%;top:50%;transform:translateY(-50%);pointer-events:none;
}

.hero-inner{position:relative;z-index:2;max-width:640px;}

.hero-sup{
display:inline-flex;align-items:center;gap:10px;
font-size:.64rem;font-weight:500;letter-spacing:2.5px;text-transform:uppercase;
color:var(–coffee);margin-bottom:6px;
animation:rise .65s ease both;
}
.hero-sup::before{content:’’;width:24px;height:1px;background:var(–stone);}

.hero-subtitle-tag{
font-size:.75rem;font-weight:400;letter-spacing:1.5px;text-transform:uppercase;
color:var(–muted);margin-bottom:24px;padding-left:34px;
animation:rise .65s .06s ease both;
}

.hero-name{
font-family:‘Alex Brush’,cursive;
font-size:clamp(2.4rem,10vw,5rem);
color:var(–coffee2);line-height:1.0;
margin-bottom:14px;
animation:rise .7s .12s ease both;
}

.hero-kabinet{
font-family:‘Cormorant Garamond’,serif;
font-size:clamp(1.05rem,3.5vw,1.45rem);
font-weight:400;font-style:italic;
color:var(–coffee2);letter-spacing:.5px;
margin-bottom:8px;
animation:rise .7s .18s ease both;
}

.hero-fullname{
font-size:.72rem;font-weight:400;letter-spacing:1.5px;
text-transform:uppercase;color:var(–muted);
margin-bottom:28px;
animation:rise .65s .22s ease both;
}

.hero-rule{
display:flex;align-items:center;gap:10px;margin-bottom:24px;
animation:rise .65s .26s ease both;
}
.hero-rule-line{width:32px;height:1px;background:var(–stone);}
.hero-rule-diamond{width:5px;height:5px;background:var(–coffee);opacity:.5;transform:rotate(45deg);}

.hero-h{
font-family:‘Cormorant Garamond’,serif;
font-size:clamp(1.3rem,5vw,2.1rem);
font-weight:300;font-style:italic;
color:var(–text2);line-height:1.5;margin-bottom:18px;
animation:rise .7s .3s ease both;
}

.hero-p{
font-size:.86rem;font-weight:300;color:var(–text2);
line-height:1.88;max-width:380px;margin-bottom:36px;
animation:rise .7s .36s ease both;
}

.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:48px;animation:rise .65s .42s ease both;}
.btn-sage{
background:var(–sage);color:#fff;border:none;
padding:14px 34px;border-radius:50px;
font-family:‘DM Sans’,sans-serif;font-size:.7rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;
cursor:pointer;transition:all .3s;-webkit-appearance:none;
box-shadow:0 6px 22px rgba(120,92,58,.12);
}
.btn-sage:hover{background:var(–sage2);transform:translateY(-2px);}
.btn-link{
font-size:.7rem;font-weight:400;letter-spacing:1.5px;text-transform:uppercase;
color:var(–muted);text-decoration:none;
display:flex;align-items:center;gap:9px;transition:color .25s;align-self:center;
}
.btn-link::after{content:‘→’;transition:margin .25s;}
.btn-link:hover{color:var(–text2);}
.btn-link:hover::after{margin-left:6px;}

/* pill badges */
.hero-pills{display:flex;flex-wrap:wrap;gap:8px;animation:rise .65s .48s ease both;}
.hpill{
background:rgba(255,252,248,.58);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
border:1px solid rgba(255,252,248,.75);
padding:7px 16px;border-radius:50px;
font-size:.7rem;font-weight:400;color:var(–text2);letter-spacing:.5px;
box-shadow:0 2px 12px rgba(46,20,24,.05);
}
/* highlighted pill */
.hpill.hl{
background:rgba(120,92,58,.07);
border-color:rgba(120,92,58,.18);
color:var(–sage2);font-weight:500;
}

@keyframes rise{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}

/* ── SOCIAL LINKS ── */
.hero-socials{
display:flex;flex-wrap:wrap;gap:12px;
margin-top:28px;
}
.hsoc{
display:inline-flex;align-items:center;gap:7px;
text-decoration:none;
font-size:.72rem;font-weight:500;letter-spacing:.5px;
color:var(–text2);
background:rgba(255,255,255,.65);backdrop-filter:blur(12px);
border:1px solid rgba(90,65,40,.1);
padding:7px 14px;border-radius:50px;
transition:all .25s;
}
.hsoc:hover{background:var(–coffee);color:#fff;border-color:var(–coffee);}
.hsoc svg{flex-shrink:0;opacity:.7;}
.hsoc:hover svg{opacity:1;}

/* ── ABOUT SECTION ── */
.about-sec{background:var(–bg2);}
.about-card{
max-width:680px;margin:0 auto;
text-align:center;position:relative;
padding:48px 32px;
}
.about-quote{
font-family:‘Alex Brush’,cursive;
font-size:8rem;line-height:.7;
color:var(–coffee);opacity:.12;
position:absolute;top:10px;left:10px;
pointer-events:none;user-select:none;
}
.about-text{
font-family:‘Cormorant Garamond’,serif;
font-size:clamp(1.2rem,4vw,1.7rem);
font-weight:400;font-style:italic;
color:var(–text);line-height:1.5;
margin-bottom:28px;
}
.about-body{
font-size:.88rem;font-weight:300;
color:var(–text2);line-height:1.85;
margin-bottom:14px;max-width:560px;margin-left:auto;margin-right:auto;
}
.about-sign{
font-family:‘Alex Brush’,cursive;
font-size:1.8rem;color:var(–coffee);
margin-top:28px;
}

/* ── SHARED SECTION ── */
.sec{position:relative;z-index:1;padding:84px 28px;}
.sec.alt{background:rgba(0,0,0,0);}
.wrap{max-width:900px;margin:0 auto;}
.s-sup{font-size:.62rem;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:var(–coffee);display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.s-sup::before{content:’’;width:20px;height:1px;background:var(–stone);}
.s-script{font-family:‘Alex Brush’,cursive;font-size:clamp(2.2rem,8vw,3.8rem);color:var(–coffee);line-height:1.05;display:block;margin-bottom:6px;}
.s-h{font-family:‘Cormorant Garamond’,serif;font-size:clamp(1.5rem,4.5vw,2.4rem);font-weight:400;color:var(–text);margin-bottom:10px;letter-spacing:-.2px;}
.s-p{font-size:.86rem;font-weight:300;color:var(–muted);line-height:1.85;max-width:420px;margin-bottom:44px;}

/* ── SERVICES ── */
.svc-list{display:flex;flex-direction:column;}
.svc-row{
display:flex;align-items:flex-start;gap:14px;
padding:20px 22px;margin-bottom:10px;
background:rgba(255,255,255,.65);
backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
border:1px solid rgba(255,255,255,.78);
border-radius:14px;
box-shadow:0 4px 22px rgba(46,34,24,.06),0 1px 4px rgba(46,34,24,.04);
transition:all .28s;
}
.svc-row:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(46,34,24,.09);}
.svc-dot{
width:2px;height:36px;border-radius:2px;flex-shrink:0;
margin-top:4px;
background:rgba(210,195,178,.5);transition:background .28s;
}
.svc-row:hover .svc-dot{background:var(–coffee);}
.svc-body{flex:1;}
.svc-nm{
font-family:‘Cormorant Garamond’,serif;font-size:1.12rem;font-weight:400;
color:var(–text);margin-bottom:4px;transition:color .22s;
}
.svc-row:hover .svc-nm{color:var(–coffee);}
.svc-ds{font-size:.78rem;font-weight:300;color:var(–muted);line-height:1.5;}
.svc-badge{
display:inline-block;margin-top:6px;
background:rgba(120,92,58,.06);border:1px solid rgba(120,92,58,.14);
color:var(–sage2);padding:2px 9px;border-radius:30px;
font-size:.6rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;
}
.svc-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;padding-left:10px;}
.svc-price{font-family:‘Cormorant Garamond’,serif;font-size:1.1rem;font-weight:400;color:var(–text);white-space:nowrap;}
.svc-dur{font-size:.62rem;font-weight:400;letter-spacing:1px;text-transform:uppercase;color:var(–muted);}
.svc-bk{
background:var(–sage);color:#fff;border:none;
padding:7px 16px;border-radius:50px;
font-family:‘DM Sans’,sans-serif;font-size:.62rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;
cursor:pointer;transition:all .22s;margin-top:6px;-webkit-appearance:none;white-space:nowrap;
}
.svc-bk:hover{background:var(–sage2);}

/* ── CAROUSEL (before/after) ── */
.car-outer{overflow:hidden;border-radius:16px;box-shadow:0 4px 28px rgba(46,20,24,.08);}
.car-track{display:flex;transition:transform .5s cubic-bezier(.25,.8,.25,1);}
.car-slide{min-width:100%;background:rgba(255,252,248,.6);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,252,248,.78);border-radius:16px;overflow:hidden;box-shadow:0 8px 40px rgba(46,34,24,.09);}
.car-imgs{display:grid;grid-template-columns:1fr 1fr;height:240px;}
.car-half{
display:flex;align-items:center;justify-content:center;flex-direction:column;gap:6px;
position:relative;font-size:.62rem;font-weight:400;letter-spacing:2px;text-transform:uppercase;color:var(–muted);
}
.car-half.before{background:rgba(240,232,220,.7);}
.car-half.after{background:rgba(216,200,180,.45);}
.car-tag{
position:absolute;bottom:12px;left:12px;
background:rgba(247,241,232,.9);backdrop-filter:blur(6px);
color:var(–coffee);font-size:.58rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;
padding:3px 10px;border-radius:30px;border:1px solid var(–line);
}
.car-info{padding:18px 22px;border-top:1px solid var(–linesm);}
.car-proc{font-family:‘Cormorant Garamond’,serif;font-size:1.15rem;font-weight:400;font-style:italic;color:var(–text);margin-bottom:4px;}
.car-desc{font-size:.76rem;font-weight:300;color:var(–muted);}
.car-ctrl{display:flex;align-items:center;justify-content:space-between;margin-top:16px;}
.car-dots{display:flex;gap:7px;align-items:center;}
.car-dot{width:18px;height:1.5px;background:var(–stone);transition:all .3s;cursor:pointer;}
.car-dot.on{width:38px;background:var(–coffee);}
.car-arrows{display:flex;gap:7px;}
.car-arr{
width:36px;height:36px;border:1px solid var(–line);background:transparent;
color:var(–muted);cursor:pointer;font-size:.85rem;border-radius:50%;
display:flex;align-items:center;justify-content:center;
transition:all .22s;-webkit-appearance:none;
}
.car-arr:hover{border-color:var(–coffee);color:var(–coffee);}

/* ── REVIEWS with semi-transparent blobs behind ── */
.rev-sec{position:relative;overflow:hidden;}
/* bg blob shapes like screenshot 7 */
.rev-blob{
position:absolute;border-radius:40% 60% 60% 40% / 50% 40% 60% 50%;
pointer-events:none;
}
.rb1{width:280px;height:360px;top:5%;right:-8%;background:rgba(220,210,200,.09);transform:rotate(-15deg);}
.rb2{width:200px;height:280px;bottom:10%;left:-6%;background:rgba(220,210,200,.09);transform:rotate(20deg);}
.rb3{width:160px;height:220px;top:50%;right:25%;background:rgba(220,210,200,.08);transform:rotate(8deg);}
.rev-list{display:flex;flex-direction:column;position:relative;z-index:2;}
.rev-item{
display:grid;grid-template-columns:50px 1fr;gap:16px;
padding:22px 20px;margin-bottom:10px;
background:rgba(255,255,255,.68);
backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
border:1px solid rgba(255,255,255,.75);
border-radius:14px;
box-shadow:0 4px 20px rgba(46,20,24,.05);
}
.rev-av{
width:46px;height:46px;border-radius:50%;
background:rgba(216,200,180,.3);border:1.5px solid var(–line);
display:flex;align-items:center;justify-content:center;
font-family:‘Alex Brush’,cursive;font-size:1.5rem;color:var(–coffee);
flex-shrink:0;
}
.rev-stars{color:var(–coffee);font-size:.75rem;letter-spacing:3px;margin-bottom:8px;}
.rev-text{
font-family:‘Cormorant Garamond’,serif;
font-size:1.02rem;font-weight:300;font-style:italic;
color:var(–text2);line-height:1.72;margin-bottom:9px;
}
.rev-who{font-size:.62rem;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;color:var(–muted);}

/* ── FAQ ── */
.faq-cols{}
.faq-cta-block{margin-bottom:44px;}
.faq-list{display:flex;flex-direction:column;}
.faq-row{background:rgba(255,255,255,.6);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.7);border-radius:12px;margin-bottom:8px;padding:0 16px;box-shadow:0 2px 14px rgba(46,34,24,.04);}
.faq-btn{
width:100%;background:none;border:none;
padding:16px 0;display:flex;justify-content:space-between;align-items:center;
font-family:‘DM Sans’,sans-serif;font-size:.87rem;font-weight:400;
color:var(–text);cursor:pointer;text-align:left;gap:14px;-webkit-appearance:none;
}
.faq-ic{
width:26px;height:26px;border-radius:50%;border:1.5px solid var(–line);
display:flex;align-items:center;justify-content:center;
font-size:.95rem;flex-shrink:0;transition:all .3s;color:var(–coffee);
}
.faq-row.open .faq-ic{background:var(–sage);color:#fff;border-color:var(–sage);transform:rotate(45deg);}
.faq-ans{max-height:0;overflow:hidden;transition:max-height .4s ease;}
.faq-ans-inner{padding-bottom:18px;font-size:.83rem;font-weight:300;color:var(–muted);line-height:1.82;}

/* ── FOOTER ── */
footer{
position:relative;z-index:1;
background:rgba(255,252,248,.45);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border-top:1px solid rgba(255,252,248,.6);
padding:56px 28px 38px;
}
.footer-inner{max-width:900px;margin:0 auto;}
.f-logo{font-family:‘Alex Brush’,cursive;font-size:2.8rem;color:var(–coffee);line-height:1;margin-bottom:3px;}
.f-name{font-size:.62rem;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;color:var(–muted);margin-bottom:3px;}
.f-kabinet{font-family:‘Cormorant Garamond’,serif;font-size:.92rem;font-style:italic;color:var(–coffee2);margin-bottom:4px;}
.f-city{font-size:.76rem;color:var(–muted);margin-bottom:30px;}
.f-nav{display:flex;flex-wrap:wrap;gap:8px 20px;margin-bottom:36px;}
.f-nav a{text-decoration:none;font-size:.68rem;font-weight:400;letter-spacing:1.5px;text-transform:uppercase;color:var(–muted);transition:color .2s;padding:3px 0;}
.f-nav a:hover{color:var(–coffee);}
.f-bottom{border-top:1px solid var(–linesm);padding-top:18px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;}
.f-copy{font-size:.62rem;color:var(–muted);}
.f-adm{font-size:.62rem;color:var(–muted);cursor:pointer;transition:color .2s;letter-spacing:.5px;}
.f-adm:hover{color:var(–coffee);}

/* ── FAB ── */
.fab{
position:fixed;bottom:24px;right:22px;z-index:600;
width:40px;height:40px;border-radius:50%;
background:rgba(247,241,232,.85);backdrop-filter:blur(12px);
border:1px solid var(–line);color:var(–coffee);font-size:.85rem;
cursor:pointer;display:flex;align-items:center;justify-content:center;
box-shadow:0 4px 16px rgba(46,34,24,.1);transition:all .22s;-webkit-appearance:none;
}
.fab:hover{background:var(–sage);color:#fff;border-color:var(–sage);}

/* ── BOOKING SHEET ── */
.book-ov{position:fixed;inset:0;z-index:500;display:flex;flex-direction:column;justify-content:flex-end;pointer-events:none;opacity:0;transition:opacity .3s;}
.book-ov.open{pointer-events:all;opacity:1;}
.book-bd{position:absolute;inset:0;background:rgba(46,34,24,.22);backdrop-filter:blur(5px);}
.book-sheet{
position:relative;z-index:1;
background:rgba(247,243,238,.96);border-top:1px solid rgba(255,255,255,.75);
border-radius:20px 20px 0 0;
max-height:92svh;display:flex;flex-direction:column;
transform:translateY(100%);transition:transform .42s cubic-bezier(.16,1,.3,1);
box-shadow:0 -4px 36px rgba(46,34,24,.1);
}
.book-ov.open .book-sheet{transform:translateY(0);}
.book-pull{width:34px;height:3.5px;background:var(–stone);border-radius:2px;margin:12px auto 0;}
.book-head{padding:15px 24px 13px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(–linesm);flex-shrink:0;}
.book-title{font-family:‘Alex Brush’,cursive;font-size:1.65rem;color:var(–coffee);}
