  if(curTab==='services'){c.innerHTML=`<div class="adm-form"><div class="adm-ft">Добавить услугу</div><div class="fg"><label class="fl">Название</label><input class="fi" id="nSN" placeholder="Название"></div><div class="fg"><label class="fl">Описание</label><input class="fi" id="nSD" placeholder="Описание"></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div class="fg"><label class="fl">Длительность</label><input class="fi" id="nSDr" placeholder="60 мин"></div><div class="fg"><label class="fl">Стоимость</label><input class="fi" id="nSP" placeholder="3 000 ₸"></div></div><div class="fg"><label class="fl">Значок (напр. Glow Skin)</label><input class="fi" id="nSB" placeholder=""></div><button class="ab" onclick="addSvc()">Добавить</button></div>${svcs.map(s=>`<div class="adm-item"><div><div class="ai-n">${s.name}</div><div class="ai-s">${s.dur||''} · ${s.price}</div></div><div class="ai-a"><button class="ab" onclick="editSvc('${s.id}')">✏️</button><button class="ab danger" onclick="delSvc('${s.id}')">🗑</button></div></div>`).join('')}`;}
  else if(curTab==='faq'){c.innerHTML=`<div class="adm-form"><div class="adm-ft">Добавить вопрос</div><div class="fg"><label class="fl">Вопрос</label><input class="fi" id="nFQ" placeholder="Вопрос"></div><div class="fg"><label class="fl">Ответ</label><textarea class="fi fta" id="nFA" placeholder="Ответ"></textarea></div><button class="ab" onclick="addFaq()">Добавить</button></div>${faqs.map(f=>`<div class="adm-item"><div><div class="ai-n">${f.q}</div><div class="ai-s">${f.a.substring(0,50)}...</div></div><div class="ai-a"><button class="ab" onclick="editFaq('${f.id}')">✏️</button><button class="ab danger" onclick="delFaq('${f.id}')">🗑</button></div></div>`).join('')}`;}

else{c.innerHTML=`<div class="adm-form"><div class="adm-ft">Закрыть слот</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div class="fg"><label class="fl">Дата</label><input type="date" class="fi" id="bDate" value="${new Date().toISOString().split('T')[0]}"></div><div class="fg"><label class="fl">Время</label><select class="fi" id="bTime">${genTO()}</select></div></div><button class="ab" onclick="blockSlot()">Закрыть</button></div><div style="font-size:.62rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:8px">Закрытые слоты</div><div class="btags">${blocked.length===0?'<span style="font-size:.7rem;color:var(--muted)">Пусто</span>':''}${blocked.map((b,i)=>`<div class="btag">${b.d} ${b.t}<button onclick="unblock(${i})">×</button></div>`).join('')}</div>`;}}
function addSvc(){const n=document.getElementById(‘nSN’).value.trim(),d=document.getElementById(‘nSD’).value.trim(),dr=document.getElementById(‘nSDr’).value.trim(),p=document.getElementById(‘nSP’).value.trim(),badge=document.getElementById(‘nSB’).value.trim();if(!n||!p)return alert(‘Заполните название и стоимость’);svcs.push({id:‘s’+Date.now(),name:n,desc:d,dur:dr,price:p,badge});save();renderSvcs();renderTC();}
function delSvc(id){if(!confirm(‘Удалить?’))return;svcs=svcs.filter(s=>s.id!==id);save();renderSvcs();renderTC();}
function editSvc(id){const s=svcs.find(x=>x.id===id);document.getElementById(‘editTitle’).textContent=‘Редактировать услугу’;document.getElementById(‘editContent’).innerHTML=`<div class="fg"><label class="fl">Название</label><input class="fi" id="e_n" value="${s.name}"></div><div class="fg"><label class="fl">Описание</label><input class="fi" id="e_d" value="${s.desc}"></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><div class="fg"><label class="fl">Длительность</label><input class="fi" id="e_dr" value="${s.dur||''}"></div><div class="fg"><label class="fl">Стоимость</label><input class="fi" id="e_p" value="${s.price}"></div></div><div class="fg"><label class="fl">Значок</label><input class="fi" id="e_b" value="${s.badge||''}"></div>`;document.getElementById(‘editSave’).onclick=()=>{s.name=document.getElementById(‘e_n’).value.trim();s.desc=document.getElementById(‘e_d’).value.trim();s.dur=document.getElementById(‘e_dr’).value.trim();s.price=document.getElementById(‘e_p’).value.trim();s.badge=document.getElementById(‘e_b’).value.trim();save();renderSvcs();renderTC();closeEdit();};document.getElementById(‘editMov’).classList.add(‘open’);}
function addFaq(){const q=document.getElementById(‘nFQ’).value.trim(),a=document.getElementById(‘nFA’).value.trim();if(!q||!a)return alert(‘Заполните вопрос и ответ’);faqs.push({id:‘f’+Date.now(),q,a});save();renderFaq();renderTC();}
function delFaq(id){if(!confirm(‘Удалить?’))return;faqs=faqs.filter(f=>f.id!==id);save();renderFaq();renderTC();}
function editFaq(id){const f=faqs.find(x=>x.id===id);document.getElementById(‘editTitle’).textContent=‘Редактировать вопрос’;document.getElementById(‘editContent’).innerHTML=`<div class="fg"><label class="fl">Вопрос</label><input class="fi" id="e_q" value="${f.q}"></div><div class="fg"><label class="fl">Ответ</label><textarea class="fi fta" id="e_a">${f.a}</textarea></div>`;document.getElementById(‘editSave’).onclick=()=>{f.q=document.getElementById(‘e_q’).value.trim();f.a=document.getElementById(‘e_a’).value.trim();save();renderFaq();renderTC();closeEdit();};document.getElementById(‘editMov’).classList.add(‘open’);}
function blockSlot(){const d=document.getElementById(‘bDate’).value,t=document.getElementById(‘bTime’).value;if(!d||!t)return;if(blocked.find(b=>b.d===d&&b.t===t))return alert(‘Уже закрыт’);blocked.push({d,t});save();renderTC();}
function unblock(i){blocked.splice(i,1);save();renderTC();}
function closeEdit(){document.getElementById(‘editMov’).classList.remove(‘open’);}

initCal();renderSvcs();renderCar();renderFaq();goStep(1);
document.addEventListener(‘keydown’,e=>{if(e.key===‘Escape’){closeBooking();closeAdmin();closeEdit();}});
</script>

</body>
</html>
